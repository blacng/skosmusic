#2. CALIFORNIA VENUE INSTANCES

mv:the-fillmore a mv:Nightclub ;
    mv:locatedInContinent mv:NorthAmerica ;
    mv:locatedInCountry mv:UnitedStates ;
    mv:offersAmenity mv:Bar ;
    mv:offersAmenity mv:WheelchairAccessible ;
    mv:offersAmenity mv:Restaurant ;
    mv:offersAmenity mv:GreenRoom ;
    mv:hasSeating true ;
    mv:hasSeatingCapacity 1315 ;
    mv:name "The Fillmore" .

mv:greek-theatre a mv:Amphitheater ;
    mv:locatedInContinent mv:NorthAmerica ;
    mv:locatedInCountry mv:UnitedStates ;
    mv:offersAmenity mv:Bar ;
    mv:offersAmenity mv:WheelchairAccessible ;
    mv:offersAmenity mv:ParkingArea ;
    mv:offersAmenity mv:GreenRoom ;
    mv:hasSeating true ;
    mv:hasSeatingCapacity 8500 ;
    mv:name "The Greek Theatre" .

mv:levis-stadium a mv:Stadium ;
    mv:locatedInContinent mv:NorthAmerica ;
    mv:locatedInCountry mv:UnitedStates ;
    mv:offersAmenity mv:Bar ;
    mv:offersAmenity mv:WheelchairAccessible ;
    mv:offersAmenity mv:Restaurant ;
    mv:offersAmenity mv:ConcessionStand ;
    mv:offersAmenity mv:ParkingArea ;
