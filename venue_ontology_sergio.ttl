@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix mv:   <http://getexcited.com/music-venues#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mv:music-venues-ontology rdf:type owl:Ontology ;
rdfs:comment "An ontology for classifying music venue types, based on the SKOS concept scheme defined in venues_type.ttl."@en ;
rdfs:seeAlso <http://getexcited.com/music-venues#venue-type> .

mv:Venue rdf:type owl:Class ;
rdfs:label "Venue"@en ;
rdfs:comment "A physical location where events, performances, or gatherings take place."@en ;
rdfs:subClassOf mv:VenueType .

mv:locatedIn rdf:type owl:ObjectProperty ;
rdfs:label "located in"@en ;
rdfs:comment "Relates a venue to its geographical location."@en ;
rdfs:domain mv:Venue ;
rdfs:range mv:Location .

mv:hasSeatingCapacity rdf:type owl:DatatypeProperty ;
rdfs:label "has seating capacity"@en ;
rdfs:comment "Indicates the number of people a venue can accommodate."@en ;
rdfs:domain mv:Venue ;
rdfs:range xsd:integer .

mv:hasSeatting rdf:type owl:DatatypeProperty ;
rdfs:label "has seating"@en ;
rdfs:comment "Indicates whether a venue has seating available."@en ;
rdfs:domain mv:Venue ;
rdfs:range mv:Setting .

mv:IndoorVenue rdf:type owl:Class ;
rdfs:label "Indoor Venue"@en ;
rdfs:comment "Venue primarily designed for events held indoors."@en ;
rdfs:subClassOf mv:Venue .

mv:OutdoorConcertVenue rdf:type owl:Class ;
rdfs:label "Outdoor Concert Venue"@en ;
rdfs:comment "Open-air venue designed for musical concerts."@en ;
rdfs:subClassOf mv:Venue .

mv:MultiUnitVenue rdf:type owl:Class ;
rdfs:label "Multi-Unit Venue"@en ;
rdfs:comment "Venue complex that contains multiple distinct event/performance spaces."@en ;
rdfs:subClassOf mv:Venue .

mv:ConcertHall rdf:type owl:Class ;
rdfs:label "Concert Hall"@en ;
rdfs:comment "Hall designed for concerts and musical performances."@en ;
rdfs:subClassOf mv:IndoorVenue .

mv:Arena rdf:type owl:Class ;
rdfs:label "Arena"@en ;
rdfs:comment "Large indoor venue with a central performance area surrounded by seating."@en ;
rdfs:subClassOf mv:IndoorVenue .

mv:Nightclub rdf:type owl:Class ;
rdfs:label "Nightclub"@en ;
rdfs:comment "Venue primarily focused on music and dancing, often with a bar."@en ;
rdfs:subClassOf mv:IndoorVenue .

mv:MusicClub rdf:type owl:Class ;
rdfs:label "Music Club"@en ;
rdfs:comment "Smaller indoor venue focused on live music performances."@en ;
rdfs:subClassOf mv:IndoorVenue .

mv:Cabaret rdf:type owl:Class ;
rdfs:label "Cabaret"@en ;
rdfs:comment "Venue offering a mix of music, comedy, and other performances in an intimate setting."@en ;
rdfs:subClassOf mv:IndoorVenue .

mv:Amphitheater rdf:type owl:Class ;
rdfs:label "Amphitheater"@en ;
rdfs:comment "Open-air venue with a stage and tiered seating, often used for concerts and performances."@en ;
rdfs:subClassOf mv:OutdoorConcertVenue .

mv:Stadium rdf:type owl:Class ;
rdfs:label "Stadium"@en ;
rdfs:comment "Large outdoor venue with a field or stage and extensive seating, often used for concerts and sporting events."@en ;
rdfs:subClassOf mv:Outdoor .

mv:Fairground rdf:type owl:Class ;
rdfs:label "Fairground"@en ;
rdfs:comment "Open outdoor area used for fairs, festivals, and large events, which may include a stage for concerts."@en ;
rdfs:subClassOf mv:OutdoorConcertVenue .

mv:PerformingArtsBuilding rdf:type owl:Class ;
rdfs:label "Performing Arts Building"@en ;
rdfs:comment "Venue complex that includes multiple performance spaces, such as theaters, concert halls, and rehearsal rooms."@en ;
rdfs:subClassOf mv:MultiUnitVenue .

mv:CommunityCenter rdf:type owl:Class ;
rdfs:label "Community Center"@en ;
rdfs:comment "Multi-purpose venue that may include spaces for performances, events, and community gatherings."@en ;
rdfs:subClassOf mv:MultiUnitVenue . 

