# ==============================================================================
# Individuals: Amenities
# ==============================================================================
# OWL type declarations for amenity concepts referenced by venue instances.
# SKOS labels, definitions, and hierarchy are in music_venue_vocabulary.ttl.

mv:AccessibilityFeature a mv:Amenity .
mv:Elevator a mv:Amenity .
mv:AssistiveListeningDevice a mv:Amenity .
mv:WheelchairAccessible a mv:Amenity .

mv:FoodAndDrink a mv:EatingOrDrinkingEstablishment ;
    skos:closeMatch mv:EatingOrDrinkingEstablishment .
mv:Bar a mv:EatingOrDrinkingEstablishment .
mv:ConcessionStand a mv:EatingOrDrinkingEstablishment .
mv:Restaurant a mv:EatingOrDrinkingEstablishment .

mv:GreenRoom a mv:Room .
