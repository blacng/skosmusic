# ── Oceania ──────────────────────────────────────

geo:Australia a geo:Country ;
    rdfs:label "Australia"@en ;
    geo:locatedInContinent geo:Oceania ;
    geo:capitalCity geo:Canberra ;
    geo:mostPopulousCity geo:Sydney .

geo:Canberra a geo:City ;
    rdfs:label "Canberra"@en ;
    rdfs:comment "Capital of Australia, home to the Canberra Theatre Centre and annual music festivals."@en ;
    geo:locatedInCountry geo:Australia .

geo:Sydney a geo:City ;
    rdfs:label "Sydney"@en ;
    rdfs:comment "Most populous Australian city, home to the Sydney Opera House and Enmore Theatre."@en ;
    geo:locatedInCountry geo:Australia .

geo:NewZealand a geo:Country ;
    rdfs:label "New Zealand"@en ;
    geo:locatedInContinent geo:Oceania ;
    geo:capitalCity geo:Wellington ;
    geo:mostPopulousCity geo:Auckland .

geo:Wellington a geo:City ;
    rdfs:label "Wellington"@en ;
    rdfs:comment "Capital of New Zealand with intimate live music venues like San Fran and Meow."@en ;
