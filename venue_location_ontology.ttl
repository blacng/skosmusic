geo:Brazil a geo:Country ;
    rdfs:label "Brazil"@en ;
    geo:locatedInContinent geo:SouthAmerica ;
    geo:capitalCity geo:Brasilia ;
    geo:mostPopulousCity geo:SaoPaulo .

geo:Brasilia a geo:City ;
    rdfs:label "Brasilia"@en ;
    rdfs:comment "Capital of Brazil, a planned city with modernist concert spaces."@en ;
    geo:locatedInCountry geo:Brazil .

geo:SaoPaulo a geo:City ;
    rdfs:label "São Paulo"@en ;
    rdfs:comment "Most populous Brazilian city and Latin America's largest music market with venues like Credicard Hall."@en ;
    geo:locatedInCountry geo:Brazil .

geo:Argentina a geo:Country ;
    rdfs:label "Argentina"@en ;
    geo:locatedInContinent geo:SouthAmerica ;
    geo:capitalCity geo:BuenosAires ;
    geo:mostPopulousCity geo:BuenosAires .

geo:BuenosAires a geo:City ;
    rdfs:label "Buenos Aires"@en ;
    rdfs:comment "Capital and most populous city, world capital of tango with legendary venues like Teatro Colón."@en ;
    geo:locatedInCountry geo:Argentina .

geo:Colombia a geo:Country ;
    rdfs:label "Colombia"@en ;
    geo:locatedInContinent geo:SouthAmerica ;
    geo:capitalCity geo:Bogota ;
    geo:mostPopulousCity geo:Bogota .

geo:Bogota a geo:City ;
    rdfs:label "Bogotá"@en ;
    rdfs:comment "Capital and most populous city, home to a growing salsa, cumbia, and electronic music scene."@en ;
    geo:locatedInCountry geo:Colombia .

