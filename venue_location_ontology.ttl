    geo:locatedInCountry geo:Spain .

# ── Asia ─────────────────────────────────────────

geo:Japan a geo:Country ;
    rdfs:label "Japan"@en ;
    geo:locatedInContinent geo:Asia ;
    geo:capitalCity geo:Tokyo ;
    geo:mostPopulousCity geo:Tokyo .

geo:Tokyo a geo:City ;
    rdfs:label "Tokyo"@en ;
    rdfs:comment "Capital and most populous city, famous for live houses, the Budokan, and Tokyo Dome."@en ;
    geo:locatedInCountry geo:Japan .

geo:SouthKorea a geo:Country ;
    rdfs:label "South Korea"@en ;
    geo:locatedInContinent geo:Asia ;
    geo:capitalCity geo:Seoul ;
    geo:mostPopulousCity geo:Seoul .

geo:Seoul a geo:City ;
    rdfs:label "Seoul"@en ;
    rdfs:comment "Capital and most populous city, the heart of K-pop with arenas like KSPO Dome and Hongdae live clubs."@en ;
