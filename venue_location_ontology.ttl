    geo:locatedInContinent geo:Africa ;
    geo:capitalCity geo:Pretoria ;
    geo:mostPopulousCity geo:Johannesburg .

geo:Pretoria a geo:City ;
    rdfs:label "Pretoria"@en ;
    rdfs:comment "Executive capital of South Africa with the State Theatre and growing jazz scene."@en ;
    geo:locatedInCountry geo:SouthAfrica .

geo:Johannesburg a geo:City ;
    rdfs:label "Johannesburg"@en ;
    rdfs:comment "Most populous South African city, birthplace of kwaito and amapiano with venues across Braamfontein."@en ;
    geo:locatedInCountry geo:SouthAfrica .

geo:Nigeria a geo:Country ;
    rdfs:label "Nigeria"@en ;
