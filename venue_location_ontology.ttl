geo:Lagos a geo:City ;
    rdfs:label "Lagos"@en ;
    rdfs:comment "Most populous Nigerian city and the beating heart of Afrobeats with venues like Eko Hotel and the Shrine."@en ;
    geo:locatedInCountry geo:Nigeria .

geo:Kenya a geo:Country ;
    rdfs:label "Kenya"@en ;
