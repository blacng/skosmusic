@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix geo:   <http://getexcited.com/music-venues/geo#> .

# ==============================================================================
# Ontology Declaration
# ==============================================================================

<http://getexcited.com/music-venues/geo>
    a owl:Ontology ;
    rdfs:label "Music Venue Location Ontology"@en ;
    rdfs:comment "Formal ontology for describing the geographic locations of music venues."@en ;
    owl:versionInfo "1.0" .

# ==============================================================================
# Classes
# ==============================================================================

geo:Location a owl:Class ;
    rdfs:label "Location"@en ;
    rdfs:comment "A geographic location associated with a music venue."@en .

geo:Continent a owl:Class ;
    rdfs:subClassOf geo:Location ;
    rdfs:label "Continent"@en ;
    rdfs:comment "A continent where music venues are located."@en .

geo:Country a owl:Class ;
    rdfs:subClassOf geo:Location ;
    rdfs:label "Country"@en ;
    rdfs:comment "A country where music venues are located."@en .

geo:City a owl:Class ;
    rdfs:subClassOf geo:Location ;
    rdfs:label "City"@en ;
    rdfs:comment "A city representing a civic and cultural center for music venues."@en .

# ==============================================================================
# Object Properties
# ==============================================================================

geo:locatedInContinent a owl:ObjectProperty ;
    rdfs:domain geo:Country ;
    rdfs:range geo:Continent ;
    rdfs:label "located in continent"@en ;
    rdfs:comment "Relates a country to the continent it belongs to."@en .

geo:locatedInCountry a owl:ObjectProperty ;
    rdfs:domain geo:City ;
    rdfs:range geo:Country ;
    rdfs:label "located in country"@en ;
    rdfs:comment "Relates a city to the country it belongs to."@en .

geo:capitalCity a owl:ObjectProperty ;
    rdfs:domain geo:Country ;
    rdfs:range geo:City ;
    rdfs:label "capital city"@en ;
    rdfs:comment "Relates a country to its capital city."@en .

geo:mostPopulousCity a owl:ObjectProperty ;
    rdfs:domain geo:Country ;
    rdfs:range geo:City ;
    rdfs:label "most populous city"@en ;
    rdfs:comment "Relates a country to its city with the highest population."@en .

# ==============================================================================
# Individuals: Continents
# ==============================================================================

geo:NorthAmerica a geo:Continent ;
    rdfs:label "North America"@en .

geo:SouthAmerica a geo:Continent ;
    rdfs:label "South America"@en .

geo:Europe a geo:Continent ;
    rdfs:label "Europe"@en .

geo:Asia a geo:Continent ;
    rdfs:label "Asia"@en .

geo:Africa a geo:Continent ;
    rdfs:label "Africa"@en .

geo:Oceania a geo:Continent ;
    rdfs:label "Oceania"@en .

# ==============================================================================
# Individuals: Countries & Cities
# ==============================================================================

# ── North America ────────────────────────────────

geo:UnitedStates a geo:Country ;
    rdfs:label "United States"@en ;
    geo:locatedInContinent geo:NorthAmerica ;
    geo:capitalCity geo:WashingtonDC ;
    geo:mostPopulousCity geo:NewYorkCity .

geo:WashingtonDC a geo:City ;
    rdfs:label "Washington, D.C."@en ;
    rdfs:comment "Capital of the United States and home to historic concert venues like the Kennedy Center."@en ;
    geo:locatedInCountry geo:UnitedStates .

geo:NewYorkCity a geo:City ;
    rdfs:label "New York City"@en ;
    rdfs:comment "Most populous U.S. city, renowned for iconic venues like Madison Square Garden and Carnegie Hall."@en ;
    geo:locatedInCountry geo:UnitedStates .

geo:Canada a geo:Country ;
    rdfs:label "Canada"@en ;
    geo:locatedInContinent geo:NorthAmerica ;
    geo:capitalCity geo:Ottawa ;
    geo:mostPopulousCity geo:Toronto .

geo:Ottawa a geo:City ;
    rdfs:label "Ottawa"@en ;
    rdfs:comment "Capital of Canada, host of the Ottawa Bluesfest and the National Arts Centre."@en ;
    geo:locatedInCountry geo:Canada .

geo:Toronto a geo:City ;
    rdfs:label "Toronto"@en ;
    rdfs:comment "Most populous Canadian city with a thriving live music scene spanning jazz, indie, and electronic venues."@en ;
    geo:locatedInCountry geo:Canada .

geo:Mexico a geo:Country ;
    rdfs:label "Mexico"@en ;
    geo:locatedInContinent geo:NorthAmerica ;
    geo:capitalCity geo:MexicoCity ;
    geo:mostPopulousCity geo:MexicoCity .

geo:MexicoCity a geo:City ;
    rdfs:label "Mexico City"@en ;
    rdfs:comment "Capital and most populous city, home to the Palacio de Bellas Artes and Foro Sol."@en ;
    geo:locatedInCountry geo:Mexico .

