    geo:capitalCity geo:Abuja ;
    geo:mostPopulousCity geo:Lagos .

geo:Abuja a geo:City ;
    rdfs:label "Abuja"@en ;
    rdfs:comment "Capital of Nigeria with emerging concert and festival venues."@en ;
