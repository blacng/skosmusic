geo:UnitedKingdom a geo:Country ;
    rdfs:label "United Kingdom"@en ;
    geo:locatedInContinent geo:Europe ;
    geo:capitalCity geo:London ;
    geo:mostPopulousCity geo:London .

geo:London a geo:City ;
    rdfs:label "London"@en ;
    rdfs:comment "Capital and most populous city, home to the Royal Albert Hall, O2 Arena, and Brixton Academy."@en ;
    geo:locatedInCountry geo:UnitedKingdom .

geo:Germany a geo:Country ;
    rdfs:label "Germany"@en ;
    geo:locatedInContinent geo:Europe ;
    geo:capitalCity geo:Berlin ;
    geo:mostPopulousCity geo:Berlin .

geo:Berlin a geo:City ;
    rdfs:label "Berlin"@en ;
    rdfs:comment "Capital and most populous city, a global epicenter of electronic music with clubs like Berghain."@en ;
    geo:locatedInCountry geo:Germany .

geo:France a geo:Country ;
    rdfs:label "France"@en ;
    geo:locatedInContinent geo:Europe ;
    geo:capitalCity geo:Paris ;
    geo:mostPopulousCity geo:Paris .

geo:Paris a geo:City ;
    rdfs:label "Paris"@en ;
    rdfs:comment "Capital and most populous city, historic home of cabaret, jazz, and the Olympia music hall."@en ;
    geo:locatedInCountry geo:France .

geo:Spain a geo:Country ;
    rdfs:label "Spain"@en ;
    geo:locatedInContinent geo:Europe ;
    geo:capitalCity geo:Madrid ;
